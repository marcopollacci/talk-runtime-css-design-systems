  </PNotes>
</p-slide>

<style lang="scss">
  [feature-support] {
    [data-box] {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4em;
      padding: 1em 1.8em;
      min-width: 6em;
      width: 28%;
    }
    .bname {
      font-size: 0.55em;
      opacity: 0.65;
      font-family: var(--talk-marco-graphik-medium, sans-serif);
      text-align: center;
      white-space: nowrap;
    }
    .bver {
      font-size: 1.1em;
      font-family: var(--font-mono, ui-monospace, monospace);
      white-space: nowrap;
      &.ok {
        color: light-dark(oklch(0.42 0.2 145), oklch(0.78 0.2 145));
      }
      &.warn {
        color: light-dark(oklch(0.55 0.2 75), oklch(0.82 0.18 75));
      }
      &.no {
        color: light-dark(oklch(0.5 0.22 25), oklch(0.72 0.22 25));
        opacity: 0.75;
      }
    }
    .bs-badge {
      font-size: 0.45em;
      opacity: 0.55;
      margin-block-start: 1.5em;
    }
  }
</style>
