<!-- ─────────────────────────────────────────────────────────────────────────
     new-css-classes.astro
     Showcase di tutti i nuovi helper aggiunti in presentation.scss [NEW].
     Una slide per famiglia di classi.
────────────────────────────────────────────────────────────────────────── --><!-- 0 ─ Copertina sezione ─────────────────────────────────────────────── -->
<p-slide class="cover-internal">
  <h2>Nuove classi CSS</h2>
  <p class="eyebrow">presentation.scss · [NEW]</p>
</p-slide>

<!-- 1 ─ Palette OKLCH ───────────────────────────────────────────────────
     Tre palette opt-in: palette-modern · palette-citrus · palette-ocean
     Si applicano su <body> o su singola <p-slide>.
──────────────────────────────────────────────────────────────────────── -->
<p-slide class="center">
  <p class="eyebrow">opt-in palette</p>
  <h2 class="main-gradient">Palette OKLCH</h2>
  <div
    class="hand-drawing-horizontal center"
    style="gap: 2rem; margin-block-start: 2rem"
  >
    <p-note
      class="center palette-modern"
      style="padding: 1.2rem 2rem; border-radius: var(--box-radius)"
    >
      <span class="main-gradient">palette-modern</span>
      <br />
      <span class="tag" style="margin-block-start: .5rem">purple → blue</span>
    </p-note>
    <p-note
      class="center palette-citrus"
      style="padding: 1.2rem 2rem; border-radius: var(--box-radius)"
    >
      <span class="main-gradient">palette-citrus</span>
      <br />
      <span class="tag" style="margin-block-start: .5rem">yellow → green</span>
    </p-note>
    <p-note
      class="center palette-ocean"
      style="padding: 1.2rem 2rem; border-radius: var(--box-radius)"
    >
      <span class="main-gradient">palette-ocean</span>
      <br />
      <span class="tag" style="margin-block-start: .5rem">aqua → deep blue</span
      >
    </p-note>
  </div>
</p-slide>

<!-- 2 ─ Gradient text ────────────────────────────────────────────────────
     .main-gradient      → var(--main-from) → var(--main-to)
     .main-sub-gradient  → var(--sub-from)  → var(--sub-to)
──────────────────────────────────────────────────────────────────────── -->
<p-slide class="center">
  <p class="eyebrow">gradient text</p>
  <h2 class="main-gradient">Headings con .main-gradient</h2>
  <p style="margin-block-start: 1.5rem; font-size: 1.4em">
    Testo normale con termine
    <span class="main-sub-gradient">.main-sub-gradient</span>
    in evidenza.
  </p>
  <hr class="divider-rule" style="margin-block: 2rem" />
  <p class="small-text" style="color: var(--ink-mute)">
    Entrambe le classi leggono <code>--main-from/to</code> e <code
      >--sub-from/to</code
    >
    — cambiano automaticamente con la palette attiva.
  </p>
</p-slide>

<!-- 3 ─ Eyebrow · Tag · Highlight ───────────────────────────────────────
     .eyebrow        monospace uppercase con letter-spacing
     .tag            pill outline
     .tag.solid      pill filled con main gradient
     .hl / .hl-blue  marker evidenziatore
──────────────────────────────────────────────────────────────────────── -->
<p-slide class="two-columns">
  <p-note>
    <p class="eyebrow">eyebrow + tag</p>
    <h3 class="main-gradient" style="margin-block: 1rem">Label helpers</h3>
    <p>
      <span class="eyebrow">Categoria</span>
    </p>
    <p style="margin-block-start: 1.2rem">
      <span class="tag">outline</span>
      &nbsp;
      <span class="tag solid">solid</span>
    </p>
  </p-note>
  <p-note>
    <p class="eyebrow">highlight marker</p>
    <h3 class="main-gradient" style="margin-block: 1rem">Text highlight</h3>
    <p style="font-size: 1.1em; line-height: 1.6">
      Il token <span class="hl">CSS custom property</span> è la chiave di un design
      system <span class="hl hl-blue">runtime-first</span>.
    </p>
  </p-note>
</p-slide>

<!-- 4 ─ Big-stat ────────────────────────────────────────────────────────
     .big-stat   numero gigante
     .stat-unit  etichetta unità in monospace
──────────────────────────────────────────────────────────────────────── -->
<p-slide class="two-columns">
  <p-note class="center">
    <p class="big-stat main-gradient" style="font-size: 5em">98</p>
    <p class="stat-unit">% token risolti a runtime</p>
  </p-note>
  <p-note class="center">
    <p class="eyebrow" style="margin-block-end: 1rem">big-stat · stat-unit</p>
    <p style="line-height: 1.6; color: var(--ink-soft)">
      <code>.big-stat</code> — numero grande<br />
      AudioWide · <code>font-size: 12em</code><br />
      <code>line-height: 0.85</code>
    </p>
    <hr class="divider-rule" style="margin-block: 1.2rem" />
    <p style="line-height: 1.6; color: var(--ink-soft)">
      <code>.stat-unit</code> — etichetta unità<br />
      monospace · <code>color: var(--ink-mute)</code>
    </p>
  </p-note>
</p-slide>

<!-- 5 ─ Box modifiers ───────────────────────────────────────────────────
     box-sharp   border-radius: 0 + hard shadow
     box-rounded border-radius: 1.2em + soft shadow
     .accent     gradient main sui box
     .sub-accent gradient sub sui box
──────────────────────────────────────────────────────────────────────── -->
<p-slide class="center">
  <p class="eyebrow">box modifiers</p>
  <h3 class="main-gradient" style="margin-block-end: 1.5rem">
    Hand-drawing box variants
  </h3>
  <div
    style="display: flex; gap: 3rem; justify-content: center; align-items: flex-start"
  >
    <div class="hand-drawing center box-sharp">
      <span box>.box-sharp</span>
      <span arrow down></span>
      <span box class="accent">.accent</span>
    </div>
    <div class="hand-drawing center box-rounded">
      <span box>.box-rounded</span>
      <span arrow down></span>
      <span box class="sub-accent">.sub-accent</span>
    </div>
  </div>
</p-slide>

<!-- 6 ─ Syntax token classes ─────────────────────────────────────────────
     .tk-kw .tk-str .tk-num .tk-fn .tk-cmt .tk-pun .tk-tag
     Utili per code snippets scritti a mano dentro <p> o <li>.
──────────────────────────────────────────────────────────────────────── -->
<p-slide class="two-columns">
  <p-note>
    <p class="eyebrow" style="margin-block-end: 0.8rem">syntax tokens</p>
    <h3 class="main-gradient" style="margin-block-end: 1rem">
      Colorazione inline
    </h3>
    <p
      style="font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.72em; line-height: 1.9; white-space: nowrap"
    >
      <span class="tk-kw">@layer</span>
      <span class="tk-fn">tokens</span>
      <span class="tk-pun">{"{"}</span><br />
      &nbsp;&nbsp;<span class="tk-tag">--color</span><span class="tk-pun"
        >:</span
      >
      <span class="tk-str">oklch(.66 .24 320)</span><span class="tk-pun">;</span
      >
      <span class="tk-cmt">/* purple */</span><br />
      &nbsp;&nbsp;<span class="tk-tag">--space</span><span class="tk-pun"
        >:</span
      >
      <span class="tk-num">1rem</span><span class="tk-pun">;</span><br />
      <span class="tk-pun">{"}"}</span>
    </p>
  </p-note>
  <!-- <p-note class="center" style="gap: 0.7rem; display: flex; flex-direction: column; align-items: flex-start; justify-content: center">
    <p class="eyebrow" style="margin-block-end: 0.5rem">legenda</p>
    <span class="tag"><span class="tk-kw">tk-kw</span> &nbsp;keyword</span>
    <span class="tag"><span class="tk-str">tk-str</span> &nbsp;string</span>
    <span class="tag"><span class="tk-num">tk-num</span> &nbsp;number</span>
    <span class="tag"><span class="tk-fn">tk-fn</span> &nbsp;function</span>
    <span class="tag"><span class="tk-cmt">tk-cmt</span> &nbsp;comment</span>
    <span class="tag"><span class="tk-pun">tk-pun</span> &nbsp;punctuation</span>
    <span class="tag"><span class="tk-tag">tk-tag</span> &nbsp;tag / prop</span>
  </p-note> -->
</p-slide>

<!-- 7 ─ Placeholders & Divider ──────────────────────────────────────────
     .image-placeholder  blocco con hatch pattern per asset mancanti
     .qr-placeholder     quadrato QR finto
     .divider-rule       <hr> linea sfumata
──────────────────────────────────────────────────────────────────────── -->
<p-slide class="two-columns">
  <p-note class="center">
    <p class="eyebrow" style="margin-block-end: 1rem">image-placeholder</p>
    <div class="image-placeholder" style="width: 18em">image asset</div>
    <hr class="divider-rule" style="margin-block: 1.2rem" />
    <p class="small-text" style="color: var(--ink-mute)">
      .divider-rule — sfuma verso destra
    </p>
  </p-note>
  <p-note class="center">
    <p class="eyebrow" style="margin-block-end: 1rem">qr-placeholder</p>
    <div class="qr-placeholder"></div>
    <p
      class="small-text"
      style="margin-block-start: 1rem; color: var(--ink-mute)"
    >
      180 × 180 px · conic-gradient
    </p>
  </p-note>
</p-slide>
